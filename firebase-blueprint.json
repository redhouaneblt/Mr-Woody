{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A wood craftsmanship service offered by Mr Woody",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the service" },
        "title": { "type": "string", "description": "Title of the service" },
        "description": { "type": "string", "description": "Detailed description of the service" },
        "benefits": { "type": "array", "items": { "type": "string" }, "description": "List of benefits" },
        "imageUrl": { "type": "string", "description": "URL to the service image" },
        "priceRange": { "type": "string", "description": "Estimated price range" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description", "imageUrl"]
    },
    "PortfolioItem": {
      "title": "Portfolio Item",
      "description": "A completed project by Mr Woody",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project" },
        "title": { "type": "string", "description": "Project title" },
        "category": { "type": "string", "description": "Project category (e.g., Kitchen, Furniture)" },
        "description": { "type": "string", "description": "Project description" },
        "imageUrl": { "type": "string", "description": "URL to the project image" },
        "beforeImageUrl": { "type": "string", "description": "Optional URL to the 'before' image" },
        "clientName": { "type": "string", "description": "Name of the client" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "category", "imageUrl"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer review for Mr Woody",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the testimonial" },
        "name": { "type": "string", "description": "Customer name" },
        "role": { "type": "string", "description": "Customer role or location" },
        "content": { "type": "string", "description": "Testimonial text" },
        "rating": { "type": "number", "description": "Star rating (1-5)" },
        "imageUrl": { "type": "string", "description": "Optional customer photo URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "content", "rating"]
    },
    "ContactSubmission": {
      "title": "Contact Submission",
      "description": "Lead captured from the contact form",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier" },
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "format": "email", "description": "Sender email" },
        "phone": { "type": "string", "description": "Sender phone number" },
        "service": { "type": "string", "description": "Requested service" },
        "message": { "type": "string", "description": "Message content" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"], "description": "Lead status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "email", "message"]
    },
    "User": {
      "title": "User",
      "description": "Application user (Admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/services/{serviceId}": { "schema": "Service", "description": "Craftsmanship services" },
    "/portfolio/{itemId}": { "schema": "PortfolioItem", "description": "Completed projects" },
    "/testimonials/{testimonialId}": { "schema": "Testimonial", "description": "Customer reviews" },
    "/contacts/{contactId}": { "schema": "ContactSubmission", "description": "Lead captures" },
    "/users/{userId}": { "schema": "User", "description": "User profiles and roles" }
  }
}
